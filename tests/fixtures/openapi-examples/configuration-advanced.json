{
    "search_fields": [
        {
            "field": "name_lt-LT",
            "position": 1,
            "boost_multiplier": 2.5,
            "match_mode": "phrase_prefix"
        },
        {
            "field": "brand_lt-LT",
            "position": 2,
            "boost_multiplier": 2.0,
            "match_mode": "fuzzy"
        },
        {
            "field": "description_lt-LT",
            "position": 3,
            "boost_multiplier": 1.0,
            "match_mode": "fuzzy"
        },
        {
            "field": "sku",
            "position": 4,
            "boost_multiplier": 3.0,
            "match_mode": "exact"
        }
    ],
    "multi_word_operator": "and",
    "fuzzy_matching": {
        "enabled": true,
        "mode": "auto",
        "min_similarity": 2
    },
    "popularity_boost": {
        "enabled": true,
        "field": "sales_count",
        "algorithm": "logarithmic",
        "max_boost": 3.0
    },
    "min_score": 0.1
}
